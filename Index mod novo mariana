                        <div id="resumo-pedido" class="space-y-3 mb-6">
                            <div class="flex justify-between items-center py-2 border-b border-gray-100">
                                <span class="text-gray-600">Produto Base</span>
                                <span id="resumo-produto" class="font-semibold text-[#5d4037]">-</span>
