                        © 2026 Ateliê Mariana Almeida. Todos os direitos reservados.
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getFirestore, collection, onSnapshot, doc, getDoc } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyA93ymW78OYYHc2qGoF-5D_RgWdCzkxh58",
            authDomain: "atelie-mariana.firebaseapp.com",
            projectId: "atelie-mariana",
            storageBucket: "atelie-mariana.firebasestorage.app",
            messagingSenderId: "416743252478",
            appId: "1:416743252478:web:543a9c03574dfca3d960af"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);

        // VARIÁVEIS GLOBAIS
        let produtoSelecionado = null;
        let todasOpcoes = [];
        let statusLoja = 'fechada';
        
        // SELEÇÕES DO USUÁRIO
        let selecao = {
            massa: null,
            recheioTrad: null,
            recheioGourmet: null,
            cobertura: null,
            decoracoes: [],
            extras: [],
            semCategoria: []
        };

        // CONFIGURAÇÃO DAS CATEGORIAS
        const configCategorias = {
            massas: { 
                id: 'massas', 
                nome: 'Massa', 
                tipo: 'radio', 
                obrigatorio: true,
                campo: 'massa',
                permiteZero: true 
            },
            recheiosTradicionais: { 
                id: 'recheiosTradicionais', 
                nome: 'Recheio Tradicional', 
                tipo: 'radio', 
                obrigatorio: false,
                campo: 'recheioTrad',
                permiteZero: true 
            },
            recheiosGourmet: { 
                id: 'recheiosGourmet', 
                nome: 'Recheio Gourmet', 
                tipo: 'radio', 
                obrigatorio: false,
                campo: 'recheioGourmet',
                permiteZero: false 
            },
            coberturas: { 
                id: 'coberturas', 
                nome: 'Cobertura', 
                tipo: 'radio', 
                obrigatorio: false,
                campo: 'cobertura',
                permiteZero: false 
            },
            decoracoes: { 
                id: 'decoracoes', 
                nome: 'Decoração', 
                tipo: 'checkbox', 
                obrigatorio: false,
                campo: 'decoracoes',
                permiteZero: false 
            },
            extras: { 
                id: 'extras', 
                nome: 'Extras', 
                tipo: 'checkbox', 
                obrigatorio: false,
                campo: 'extras',
                permiteZero: false 
            },
            semCategoria: { 
                id: 'semCategoria', 
                nome: 'Outros', 
                tipo: 'checkbox', 
                obrigatorio: false,
                campo: 'semCategoria',
                permiteZero: false 
            }
        };

        // INICIALIZAR
        document.addEventListener('DOMContentLoaded', () => {
            carregarStatusLoja();
            carregarProdutos();
            carregarOpcoes();
        });

        // CARREGAR STATUS DA LOJA
        function carregarStatusLoja() {
            onSnapshot(doc(db, "config", "loja"), (doc) => {
                if (doc.exists()) {
                    statusLoja = doc.data().status || 'fechada';
                    atualizarBarraStatus();
                }
            });
        }

        function atualizarBarraStatus() {
            const barra = document.getElementById('status-loja-bar');
            const texto = document.getElementById('status-loja-texto');
            
            if (statusLoja === 'aberta') {
                barra.className = 'fixed top-0 left-0 right-0 z-50 text-white text-center py-2 px-4 text-sm font-semibold transition-all duration-300 status-aberto';
                texto.innerHTML = '<i class="fas fa-store mr-2"></i> Loja Aberta - Monte seu bolo!';
            } else {
                barra.className = 'fixed top-0 left-0 right-0 z-50 text-white text-center py-2 px-4 text-sm font-semibold transition-all duration-300 status-fechado';
                texto.innerHTML = '<i class="fas fa-clock mr-2"></i> Loja Fechada - Volte mais tarde';
            }
            
            atualizarBotaoPedido();
        }

        // CARREGAR PRODUTOS
        function carregarProdutos() {
            onSnapshot(collection(db, "produtos"), (snapshot) => {
                const grid = document.getElementById('produtos-grid');
                grid.innerHTML = '';
                
                const produtosAtivos = [];
                snapshot.forEach((doc) => {
                    const produto = { id: doc.id, ...doc.data() };
                    if (produto.status === 'ativo') {
                        produtosAtivos.push(produto);
                    }
                });

                if (produtosAtivos.length === 0) {
                    grid.innerHTML = `
                        <div class="col-span-full text-center py-12 text-[#a1887f]">
                            <i class="fas fa-cookie-bite text-4xl mb-4"></i>
                            <p>Nenhum produto disponível no momento</p>
                        </div>
                    `;
                    return;
                }

                produtosAtivos.forEach((produto, index) => {
                    const card = document.createElement('div');
                    card.className = 'bg-white rounded-3xl overflow-hidden card-shadow hover-lift fade-in cursor-pointer';
                    card.style.animationDelay = `${index * 0.1}s`;
                    
                    card.innerHTML = `
                        <div class="relative h-64 overflow-hidden group">
                            <img src="${produto.foto || 'https://via.placeholder.com/400x300?text=Sem+Foto'}" 
                                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                                 onerror="this.src='https://via.placeholder.com/400x300?text=Sem+Foto'">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                            <div class="absolute bottom-0 left-0 right-0 p-4 transform translate-y-full group-hover:translate-y-0 transition-transform duration-300">
                                <span class="bg-white text-[#5d4037] px-4 py-2 rounded-full font-bold text-sm">Clique para personalizar</span>
                            </div>
                        </div>
                        <div class="p-6">
                            <h3 class="text-xl font-bold text-[#5d4037] mb-2 font-serif">${produto.nome}</h3>
                            <p class="text-[#a1887f] text-sm mb-4 line-clamp-2">${produto.descricao || ''}</p>
                            
                            <div class="flex items-center justify-between">
                                <span class="text-2xl font-bold text-[#5d4037]">R$ ${produto.preco ? produto.preco.toFixed(2) : '0.00'}</span>
                                <button onclick="selecionarProduto('${produto.id}')" class="btn-primary text-white px-6 py-3 rounded-full font-semibold text-sm flex items-center gap-2">
                                    <span>Montar</span>
                                    <i class="fas fa-arrow-right"></i>
                                </button>
                            </div>
                        </div>
                    `;
                    grid.appendChild(card);
                });
            });
        }

        // CARREGAR OPÇÕES
        function carregarOpcoes() {
            onSnapshot(collection(db, "adicionais"), (snapshot) => {
                todasOpcoes = [];
                snapshot.forEach((doc) => {
                    const opcao = { id: doc.id, ...doc.data() };
                    if (opcao.status === 'ativo') {
                        // Garantir categoria
                        if (!opcao.categoria) {
                            opcao.categoria = 'semCategoria';
                        }
                        todasOpcoes.push(opcao);
                    }
                });
                
                if (produtoSelecionado) {
                    renderizarOpcoes();
                }
            });
        }

        // SELECIONAR PRODUTO
        window.selecionarProduto = async (produtoId) => {
            const docRef = doc(db, "produtos", produtoId);
            const docSnap = await getDoc(docRef);
            
            if (!docSnap.exists()) return;
            
            produtoSelecionado = { id: produtoId, ...docSnap.data() };
            
            // Resetar seleções
            selecao = {
                massa: null,
                recheioTrad: null,
                recheioGourmet: null,
                cobertura: null,
                decoracoes: [],
                extras: [],
                semCategoria: []
            };
            
            // Atualizar UI
            document.getElementById('produto-selecionado-img').src = produtoSelecionado.foto || '';
            document.getElementById('produto-selecionado-nome').textContent = produtoSelecionado.nome;
            document.getElementById('produto-selecionado-preco').textContent = `R$ ${produtoSelecionado.preco.toFixed(2)}`;
            
            // Trocar etapas
            document.getElementById('etapa-1').classList.remove('etapa-ativa');
            document.getElementById('etapa-1').classList.add('etapa-completa');
            document.getElementById('etapa-2').classList.remove('bg-gray-200', 'text-gray-500');
            document.getElementById('etapa-2').classList.add('etapa-ativa');
            
            // Mostrar personalização
            document.getElementById('secao-produtos').classList.add('hidden');
            document.getElementById('secao-personalizacao').classList.remove('hidden');
            
            renderizarOpcoes();
            atualizarResumo();
        };

        window.voltarParaProdutos = () => {
            produtoSelecionado = null;
            
            // Resetar etapas
            document.getElementById('etapa-1').classList.add('etapa-ativa');
            document.getElementById('etapa-1').classList.remove('etapa-completa');
            document.getElementById('etapa-2').classList.add('bg-gray-200', 'text-gray-500');
            document.getElementById('etapa-2').classList.remove('etapa-ativa');
            
            // Trocar seções
            document.getElementById('secao-personalizacao').classList.add('hidden');
            document.getElementById('secao-produtos').classList.remove('hidden');
        };

        // RENDERIZAR OPÇÕES
        function renderizarOpcoes() {
            // Agrupar opções por categoria
            const opcoesPorCategoria = {};
            Object.keys(configCategorias).forEach(cat => {
                opcoesPorCategoria[cat] = [];
            });
            
            todasOpcoes.forEach(opcao => {
                const cat = opcao.categoria || 'semCategoria';
                if (opcoesPorCategoria[cat]) {
                    opcoesPorCategoria[cat].push(opcao);
                }
            });
            
            // Renderizar cada categoria
            Object.keys(configCategorias).forEach(catKey => {
                const config = configCategorias[catKey];
                const opcoes = opcoesPorCategoria[catKey];
                const container = document.getElementById(`lista-${catKey.replace(/([A-Z])/g, '-$1').toLowerCase()}`);
                const secao = document.getElementById(`secao-${catKey.replace(/([A-Z])/g, '-$1').toLowerCase()}`);
                
                if (!container || !secao) return;
                
                if (opcoes.length === 0) {
                    secao.classList.add('hidden');
                    return;
                }
                
                secao.classList.remove('hidden');
                container.innerHTML = '';
                
                opcoes.forEach(opcao => {
                    const item = criarItemOpcao(opcao, config);
                    container.appendChild(item);
                });
            });
        }

        function criarItemOpcao(opcao, config) {
            const div = document.createElement('div');
            const isSelecionado = verificarSeSelecionado(opcao, config);
            const valorTexto = opcao.valor === 0 ? '<span class="text-green-600 font-medium text-sm">Incluído</span>' : `<span class="text-[#a67c52] font-bold">+ R$ ${opcao.valor.toFixed(2)}</span>`;
            
            div.className = `opcao-card p-4 rounded-xl border-2 ${isSelecionado ? 'border-[#5d4037] bg-white opcao-selecionada' : 'border-transparent bg-white/50 hover:bg-white'} flex items-center justify-between`;
            
            if (config.tipo === 'radio') {
                div.innerHTML = `
                    <div class="flex items-center gap-3">
                        <input type="radio" 
                               name="${config.campo}" 
                               value="${opcao.id}" 
                               ${isSelecionado ? 'checked' : ''}
                               onchange="selecionarOpcao('${config.campo}', '${opcao.id}', ${opcao.valor})"
                               class="radio-custom">
                        <span class="font-medium text-[#5d4037]">${opcao.nome}</span>
                    </div>
                    ${valorTexto}
                `;
            } else {
                div.innerHTML = `
                    <div class="flex items-center gap-3">
                        <input type="checkbox" 
                               value="${opcao.id}"
                               ${isSelecionado ? 'checked' : ''}
                               onchange="toggleMultiplo('${config.campo}', '${opcao.id}', ${opcao.valor}, this.checked)"
                               class="checkbox-custom">
                        <span class="font-medium text-[#5d4037]">${opcao.nome}</span>
                    </div>
                    ${valorTexto}
                `;
            }
            
            // Clique no card também seleciona
            div.addEventListener('click', (e) => {
                if (e.target.tagName !== 'INPUT') {
                    const input = div.querySelector('input');
                    input.checked = !input.checked;
                    input.dispatchEvent(new Event('change'));
                }
            });
            
            return div;
        }

        function verificarSeSelecionado(opcao, config) {
            if (config.tipo === 'radio') {
                return selecao[config.campo] && selecao[config.campo].id === opcao.id;
            } else {
                return selecao[config.campo].some(item => item.id === opcao.id);
            }
        }

        // CONTROLE DE SELEÇÃO
        window.selecionarOpcao = (campo, id, valor) => {
            const opcao = todasOpcoes.find(o => o.id === id);
            if (opcao) {
                selecao[campo] = opcao;
                
                // Se selecionar gourmet, limpa tradicional e vice-versa
                if (campo === 'recheioGourmet' && opcao) {
                    selecao.recheioTrad = null;
                } else if (campo === 'recheioTrad' && opcao) {
                    selecao.recheioGourmet = null;
                }
                
                renderizarOpcoes();
                atualizarResumo();
            }
        };

        window.toggleMultiplo = (campo, id, valor, checked) => {
            const opcao = todasOpcoes.find(o => o.id === id);
            if (!opcao) return;
            
            if (checked) {
                selecao[campo].push(opcao);
            } else {
                selecao[campo] = selecao[campo].filter(item => item.id !== id);
            }
            
            renderizarOpcoes();
            atualizarResumo();
        };

        // ATUALIZAR RESUMO
        function atualizarResumo() {
            const container = document.getElementById('resumo-itens');
            container.innerHTML = '';
            
            let total = produtoSelecionado ? produtoSelecionado.preco : 0;
            
            // Produto base
            document.getElementById('resumo-produto').textContent = produtoSelecionado ? `R$ ${produtoSelecionado.preco.toFixed(2)}` : '-';
            
            // Itens selecionados
            Object.keys(configCategorias).forEach(catKey => {
                const config = configCategorias[catKey];
                const selecionados = config.tipo === 'radio' 
                    ? (selecao[config.campo] ? [selecao[config.campo]] : [])
                    : selecao[config.campo];
                
                selecionados.forEach(item => {
                    if (item && item.valor > 0) {
                        total += item.valor;
                        const div = document.createElement('div');
                        div.className = 'resumo-item flex justify-between items-center py-1 text-sm';
                        div.innerHTML = `
                            <span class="text-gray-600">${config.nome}: ${item.nome}</span>
                            <span class="font-semibold text-[#a67c52]">+ R$ ${item.valor.toFixed(2)}</span>
                        `;
                        container.appendChild(div);
                    } else if (item) {
                        const div = document.createElement('div');
                        div.className = 'resumo-item flex justify-between items-center py-1 text-sm';
                        div.innerHTML = `
                            <span class="text-gray-600">${config.nome}: ${item.nome}</span>
                            <span class="text-green-600 text-xs">Incluído</span>
                        `;
                        container.appendChild(div);
                    }
                });
            });
            
            document.getElementById('valor-total').textContent = `R$ ${total.toFixed(2)}`;
        }

        function atualizarBotaoPedido() {
            const btn = document.getElementById('btn-whatsapp');
            const aviso = document.getElementById('aviso-fechado');
            
            if (statusLoja === 'aberta') {
                btn.classList.remove('hidden');
                aviso.classList.add('hidden');
            } else {
                btn.classList.add('hidden');
                aviso.classList.remove('hidden');
            }
        }

        // ENVIAR WHATSAPP
        window.enviarWhatsApp = () => {
            if (!produtoSelecionado) return;
            
            const numeroWhatsApp = "5512996733698";
            
            let mensagem = `🧁 *Pedido - Ateliê Mariana Almeida*\\n\\n`;
            mensagem += `*🎂 Produto:* ${produtoSelecionado.nome}\\n`;
            mensagem += `*💰 Preço Base:* R$ ${produtoSelecionado.preco.toFixed(2)}\\n\\n`;
            
            mensagem += `*📋 Personalização:*\\n`;
            
            // Massa
            if (selecao.massa) {
                mensagem += `🍰 *Massa:* ${selecao.massa.nome}\\n`;
            }
            
            // Recheio
            if (selecao.recheioGourmet) {
                mensagem += `✨ *Recheio Gourmet:* ${selecao.recheioGourmet.nome}`;
                if (selecao.recheioGourmet.valor > 0) {
                    mensagem += ` (+R$ ${selecao.recheioGourmet.valor.toFixed(2)})`;
                }
                mensagem += `\\n`;
            } else if (selecao.recheioTrad) {
                mensagem += `🥄 *Recheio:* ${selecao.recheioTrad.nome}\\n`;
            }
            
            // Cobertura
            if (selecao.cobertura) {
                mensagem += `🍫 *Cobertura:* ${selecao.cobertura.nome}`;
                if (selecao.cobertura.valor > 0) {
                    mensagem += ` (+R$ ${selecao.cobertura.valor.toFixed(2)})`;
                }
                mensagem += `\\n`;
            }
            
            // Decorações
            if (selecao.decoracoes.length > 0) {
                mensagem += `🎨 *Decorações:*\\n`;
                selecao.decoracoes.forEach(d => {
                    mensagem += `   • ${d.nome}`;
                    if (d.valor > 0) mensagem += ` (+R$ ${d.valor.toFixed(2)})`;
                    mensagem += `\\n`;
                });
            }
            
            // Extras
            if (selecao.extras.length > 0) {
                mensagem += `➕ *Extras:*\\n`;
                selecao.extras.forEach(e => {
