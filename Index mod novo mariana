                        <!-- BOTÃO WHATSAPP -->
                        <button id="btn-whatsapp" onclick="enviarWhatsApp()" class="w-full btn-whatsapp text-white py-4 rounded-2xl font-bold text-lg flex items-center justify-center gap-3 hover:shadow-lg transition-all mb-3">
                            <i class="fab fa-whatsapp text-2xl"></i>
                            <span>Fazer Pedido</span>
                        </button>

                        <!-- AVISO LOJA FECHADA -->
                        <div id="aviso-fechado" class="hidden bg-red-50 border border-red-200 text-red-700 p-4 rounded-xl text-center">
                            <i class="fas fa-clock mb-2 text-2xl"></i>
                            <p class="font-semibold">Loja Fechada</p>
