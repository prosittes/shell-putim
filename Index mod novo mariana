                    <!-- CATEGORIAS DE OPÇÕES -->
                    <div id="container-opcoes" class="space-y-6">
                        <!-- Massas -->
                        <div id="secao-massas" class="categoria-section cat-massas bg-white rounded-2xl p-6 card-shadow">
