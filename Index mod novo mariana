    <main class="max-w-6xl mx-auto px-4 py-12">
        
        <!-- ETAPAS DO PEDIDO -->
        <div class="flex justify-center mb-12">
            <div class="flex items-center gap-4 bg-white rounded-full px-6 py-3 card-shadow">
