                        <!-- Extras -->
                        <div id="secao-extras" class="categoria-section cat-extras bg-white rounded-2xl p-6 card-shadow">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="text-2xl">➕</span>
                                <div>
                                    <h3 class="text-lg font-bold text-[#5d4037]">Extras</h3>
                                    <p class="text-xs text-gray-500">Toques especiais adicionais</p>
                                </div>
                            </div>
                            <div id="lista-extras" class="space-y-2"></div>
                        </div>

                        <!-- Sem Categoria (itens antigos) -->
