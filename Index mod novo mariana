                        <!-- Coberturas -->
                        <div id="secao-coberturas" class="categoria-section cat-coberturas bg-white rounded-2xl p-6 card-shadow">
                            <div class="flex items-center gap-3 mb-4">
                                <span class="text-2xl">🍫</span>
                                <div>
                                    <h3 class="text-lg font-bold text-[#5d4037]">Cobertura</h3>
                                    <p class="text-xs text-gray-500">Selecione 1 opção</p>
                                </div>
                            </div>
                            <div id="lista-coberturas" class="space-y-2"></div>
