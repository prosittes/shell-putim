        <!-- ETAPA 2: PERSONALIZAÇÃO (inicialmente oculta) -->
        <div id="secao-personalizacao" class="hidden fade-in">
            <div class="flex flex-col lg:flex-row gap-8">
                
                <!-- COLUNA ESQUERDA: OPÇÕES -->
                <div class="lg:w-2/3 space-y-6">
                    
                    <!-- BOTÃO VOLTAR -->
                    <button onclick="voltarParaProdutos()" class="flex items-center gap-2 text-[#a67c52] hover:text-[#5d4037] font-semibold transition-colors">
