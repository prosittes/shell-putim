<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ateliê Mariana Almeida - Monte seu Bolo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --rose-pastel: #fdf2f2;
            --rose-medio: #fce7e7;
            --rose-escuro: #fda4af;
            --bege: #faf7f5;
            --marrom-claro: #a67c52;
            --marrom: #5d4037;
            --marrom-escuro: #3e2723;
            --creme: #fff8f0;
        }
        
        body {
            font-family: 'Lato', sans-serif;
            background-color: var(--bege);
            color: var(--marrom-escuro);
        }
        
        h1, h2, h3, h4, .font-serif {
            font-family: 'Playfair Display', serif;
        }
        
        .gradient-hero {
            background: linear-gradient(135deg, var(--rose-pastel) 0%, var(--creme) 50%, var(--bege) 100%);
        }
        
        .card-shadow {
            box-shadow: 0 10px 40px -10px rgba(166, 124, 82, 0.15);
        }
        
        .hover-lift {
            transition: all 0.3s ease;
        }
        
        .hover-lift:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px -10px rgba(166, 124, 82, 0.25);
        }
        
        .btn-primary {
            background: linear-gradient(135deg, var(--marrom) 0%, var(--marrom-escuro) 100%);
            transition: all 0.3s ease;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(93, 64, 55, 0.3);
        }
        
        .btn-whatsapp {
            background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
        }
        
        .status-aberto {
            background: linear-gradient(90deg, #10b981 0%, #059669 100%);
        }
        
        .status-fechado {
            background: linear-gradient(90deg, #ef4444 0%, #dc2626 100%);
        }
        
        .fade-in {
            animation: fadeIn 0.6s ease-in;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* Estilos das opções de categoria */
        .categoria-section {
            border-left: 4px solid transparent;
            transition: all 0.3s ease;
        }
        
        .cat-massas { border-left-color: #f59e0b; background: #fffbeb; }
        .cat-recheios-trad { border-left-color: #3b82f6; background: #eff6ff; }
        .cat-recheios-gourmet { border-left-color: #ec4899; background: #fdf2f8; }
        .cat-coberturas { border-left-color: #6366f1; background: #eef2ff; }
        .cat-decoracoes { border-left-color: #8b5cf6; background: #faf5ff; }
        .cat-extras { border-left-color: #10b981; background: #f0fdf4; }
        
        .opcao-card {
            transition: all 0.2s ease;
            cursor: pointer;
        }
        
        .opcao-card:hover {
            transform: translateX(4px);
        }
        
        .opcao-selecionada {
            ring-width: 2px;
            ring-color: var(--marrom);
            background-color: white;
            box-shadow: 0 4px 12px rgba(93, 64, 55, 0.15);
        }
        
        .radio-custom {
            appearance: none;
            width: 20px;
            height: 20px;
            border: 2px solid #d1d5db;
            border-radius: 50%;
            cursor: pointer;
            position: relative;
            transition: all 0.2s;
        }
        
        .radio-custom:checked {
            border-color: var(--marrom);
            background-color: var(--marrom);
        }
        
        .radio-custom:checked::after {
            content: '';
            position: absolute;
            width: 8px;
            height: 8px;
            background: white;
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
        
        .checkbox-custom {
            appearance: none;
            width: 20px;
            height: 20px;
            border: 2px solid #d1d5db;
            border-radius: 4px;
            cursor: pointer;
            position: relative;
            transition: all 0.2s;
        }
        
        .checkbox-custom:checked {
            background-color: var(--marrom);
            border-color: var(--marrom);
        }
        
        .checkbox-custom:checked::after {
            content: '✓';
            position: absolute;
            color: white;
            font-size: 14px;
            top: -2px;
            left: 3px;
        }
        
        .resumo-item {
            animation: slideIn 0.3s ease;
        }
        
        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-10px); }
            to { opacity: 1; transform: translateX(0); }
        }
        
        .modal-backdrop {
            backdrop-filter: blur(5px);
        }
        
        .etapa-indicator {
            transition: all 0.3s ease;
        }
        
        .etapa-ativa {
            background-color: var(--marrom);
            color: white;
        }
        
        .etapa-completa {
            background-color: #10b981;
            color: white;
        }
    </style>
</head>
<body class="antialiased">

    <!-- BARRA DE STATUS -->
