                    </a>
                    <a href="https://wa.me/5512996733698" class="w-10 h-10 rounded-full bg-[#fdf2f2] flex items-center justify-center text-[#5d4037] hover:bg-[#5d4037] hover:text-white transition-all">
                        <i class="fab fa-whatsapp"></i>
                    </a>
