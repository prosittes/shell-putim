                    if (e.valor > 0) mensagem += ` (+R$ ${e.valor.toFixed(2)})`;
                    mensagem += `\\n`;
                });
            }
            
            // Outros (sem categoria)
            if (selecao.semCategoria.length > 0) {
                mensagem += `📦 *Outros:*\\n`;
                selecao.semCategoria.forEach(s => {
                    mensagem += `   • ${s.nome}`;
                    if (s.valor > 0) mensagem += ` (+R$ ${s.valor.toFixed(2)})`;
                    mensagem += `\\n`;
                });
            }
            
            // Total
            const total = calcularTotal();
            mensagem += `\\n*💵 Total do Pedido: R$ ${total.toFixed(2)}*\\n\\n`;
            mensagem += `Gostaria de finalizar meu pedido! 😊`;
            
            const url = `https://wa.me/${numeroWhatsApp}?text=${encodeURIComponent(mensagem)}`;
            window.open(url, '_blank');
        };

        function calcularTotal() {
            let total = produtoSelecionado ? produtoSelecionado.preco : 0;
            
            Object.keys(configCategorias).forEach(catKey => {
                const config = configCategorias[catKey];
                const selecionados = config.tipo === 'radio' 
                    ? (selecao[config.campo] ? [selecao[config.campo]] : [])
                    : selecao[config.campo];
                
                selecionados.forEach(item => {
                    if (item) total += item.valor;
                });
            });
            
            return total;
        }
