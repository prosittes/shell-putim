<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel ADM - Ateliê Mariana Almeida</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Montserrat', sans-serif; }
        .preview-img { max-height: 200px; object-fit: cover; }
        textarea { resize: vertical; }
        .toggle-checkbox:checked { right: 0; border-color: #5d4037; }
        .toggle-checkbox:checked + .toggle-label { background-color: #5d4037; }
        .status-aberta { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
        .status-fechada { background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); }
    </style>
<base target="_blank">
</head>
<body class="bg-gray-50 p-4 min-h-screen flex flex-col">

    <!-- ÁREA DE LOGIN -->
    <div id="login-area" class="max-w-sm mx-auto mt-20 bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center mb-6">
            <h2 class="text-2xl font-bold text-[#5d4037]">Acesso da Mariana</h2>
            <p class="text-gray-400 text-sm">Digite sua senha para gerenciar</p>
        </div>
        <input type="password" id="senha" placeholder="Senha (mariana2026)" class="w-full border p-3 mb-4 rounded-xl focus:ring-2 focus:ring-[#d7ccc8] outline-none">
        <button onclick="verificarSenha()" class="w-full bg-[#5d4037] text-white p-3 rounded-xl font-bold hover:bg-[#4e342e] transition-all">Entrar no Painel</button>
    </div>

    <!-- ÁREA ADMIN -->
    <div id="admin-area" class="max-w-4xl mx-auto hidden flex-1 w-full">
        
        <!-- HEADER COM STATUS DA LOJA -->
        <header class="mb-6">
            <div class="bg-white p-4 rounded-2xl shadow-sm flex flex-col md:flex-row justify-between items-center gap-4">
                <div>
                    <h1 class="text-xl font-bold text-[#5d4037]">Gerenciar Ateliê</h1>
                    <p class="text-xs text-gray-500">Sistema completo de cardápio</p>
                </div>
                
                <!-- CONTROLE STATUS DA LOJA -->
                <div class="flex items-center gap-3 bg-gray-50 px-4 py-3 rounded-xl border border-gray-200">
                    <span class="text-sm font-semibold text-gray-600">Status da Loja:</span>
                    <button onclick="toggleStatusLoja()" id="btn-status-loja" class="px-4 py-2 rounded-lg text-white font-bold text-sm transition-all shadow-md hover:shadow-lg transform hover:scale-105">
                        Carregando...
                    </button>
                </div>
                
                <button onclick="location.reload()" class="text-sm bg-gray-100 px-4 py-2 rounded-lg text-gray-500 hover:bg-red-50 hover:text-red-500 transition-all">Sair</button>
            </div>
        </header>

        <!-- NAVEGAÇÃO POR ABAS -->
        <div class="bg-white rounded-2xl shadow-sm mb-6 overflow-hidden">
            <div class="flex border-b border-gray-200">
                <button onclick="mostrarAba('produtos')" id="aba-produtos" class="flex-1 py-4 px-6 font-semibold text-[#5d4037] border-b-2 border-[#5d4037] bg-[#faf7f5] transition-all">
                    🧁 Produtos
                </button>
                <button onclick="mostrarAba('adicionais')" id="aba-adicionais" class="flex-1 py-4 px-6 font-semibold text-gray-500 hover:text-[#5d4037] transition-all">
                    ➕ Adicionais
                </button>
            </div>
        </div>

        <!-- ABA PRODUTOS -->
        <div id="conteudo-produtos" class="space-y-6">
            
            <!-- BOTÃO NOVO PRODUTO -->
            <button onclick="abrirModalProduto()" class="w-full bg-[#5d4037] text-white p-4 rounded-xl font-bold shadow-lg hover:shadow-none transition-all flex items-center justify-center gap-2">
                <span class="text-2xl">+</span> Adicionar Novo Produto
            </button>

            <!-- LISTA DE PRODUTOS -->
            <div class="bg-white rounded-2xl shadow-md p-6">
                <h3 class="font-bold text-[#5d4037] mb-4 flex items-center gap-2">
                    📦 Produtos Cadastrados
                </h3>
                <div id="lista-produtos" class="grid gap-4">
                    <p class="text-center text-gray-400 py-8">Carregando produtos...</p>
                </div>
            </div>
        </div>

        <!-- ABA ADICIONAIS -->
        <div id="conteudo-adicionais" class="space-y-6 hidden">
            
            <!-- BOTÃO NOVO ADICIONAL -->
            <button onclick="abrirModalAdicional()" class="w-full bg-amber-600 text-white p-4 rounded-xl font-bold shadow-lg hover:shadow-none transition-all flex items-center justify-center gap-2">
                <span class="text-2xl">+</span> Adicionar Novo Adicional
            </button>

            <!-- LISTA DE ADICIONAIS -->
            <div class="bg-white rounded-2xl shadow-md p-6">
                <h3 class="font-bold text-amber-700 mb-4 flex items-center gap-2">
                    ➕ Adicionais Disponíveis
                </h3>
                <div id="lista-adicionais" class="grid gap-4">
                    <p class="text-center text-gray-400 py-8">Carregando adicionais...</p>
                </div>
            </div>
        </div>

    </div>

    <!-- MODAL PRODUTO (ADD/EDIT) -->
    <div id="modal-produto" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl">
            <div class="sticky top-0 bg-white border-b p-4 flex justify-between items-center rounded-t-2xl">
                <h3 id="titulo-modal-produto" class="text-xl font-bold text-[#5d4037]">Novo Produto</h3>
                <button onclick="fecharModalProduto()" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
            </div>
            
            <div class="p-6 space-y-4">
                <input type="hidden" id="produto-id">
                
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Nome do Produto *</label>
                    <input type="text" id="produto-nome" placeholder="Ex: Bolo de Chocolate" class="w-full border p-3 rounded-xl outline-none focus:border-[#5d4037] focus:ring-2 focus:ring-[#d7ccc8]">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Preço Base (R$) *</label>
                        <input type="number" id="produto-preco" placeholder="0.00" step="0.01" class="w-full border p-3 rounded-xl outline-none focus:border-[#5d4037]">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Status</label>
                        <select id="produto-status" class="w-full border p-3 rounded-xl outline-none focus:border-[#5d4037]">
                            <option value="ativo">✅ Ativo</option>
                            <option value="inativo">❌ Inativo</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Descrição Curta</label>
                    <textarea id="produto-desc" placeholder="Breve descrição do produto..." class="w-full border p-3 rounded-xl outline-none focus:border-[#5d4037] h-20"></textarea>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Especificações / Cardápio Completo</label>
                    <textarea id="produto-especificacoes" placeholder="📌 INFORMAÇÕES IMPORTANTES
• Serve X pessoas
• Prazo de entrega

🍰 MASSAS DISPONÍVEIS
• Chocolate
• Baunilha

🍫 RECHEIOS
• Brigadeiro
• Ninho

✨ ADICIONAIS
• Topo personalizado: +R$X" class="w-full border p-3 rounded-xl outline-none focus:border-[#5d4037] focus:ring-2 focus:ring-[#d7ccc8] h-48 text-sm"></textarea>
                    <p class="text-xs text-gray-500 mt-1">Use emojis e organize por categorias</p>
                </div>

                <!-- UPLOAD DE FOTO -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Foto do Produto</label>
                    <div class="border-2 border-dashed border-[#d7ccc8] rounded-xl p-4 text-center bg-[#faf7f5]">
                        <input type="file" id="produto-foto-input" accept="image/png,image/jpeg,image/jpg,image/webp" class="hidden" onchange="previewFotoProduto(this)">
                        
                        <div id="produto-upload-area" onclick="document.getElementById('produto-foto-input').click()">
                            <div class="text-3xl mb-2">📷</div>
                            <p class="text-[#5d4037] font-medium text-sm">Clique para adicionar foto</p>
                        </div>

                        <div id="produto-preview-area" class="hidden mt-3">
                            <img id="produto-preview-img" class="h-32 rounded-lg mx-auto object-cover shadow-md">
                            <button onclick="removerFotoProduto()" class="text-xs text-red-500 mt-2 underline">Trocar foto</button>
                        </div>

                        <div id="produto-progress" class="hidden mt-3">
                            <div class="w-full bg-gray-200 rounded-full h-2">
                                <div id="produto-progress-bar" class="bg-[#5d4037] h-2 rounded-full transition-all" style="width: 0%"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex gap-3 pt-4 border-t">
                    <button onclick="fecharModalProduto()" class="flex-1 bg-gray-200 text-gray-700 p-3 rounded-xl font-semibold hover:bg-gray-300 transition-all">Cancelar</button>
                    <button onclick="salvarProduto()" id="btn-salvar-produto" class="flex-1 bg-[#5d4037] text-white p-3 rounded-xl font-bold shadow-lg hover:shadow-none transition-all">Salvar Produto</button>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL ADICIONAL (ADD/EDIT) - ATUALIZADO COM SELETOR DE PRODUTO -->
    <div id="modal-adicional" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl max-w-md w-full shadow-2xl">
            <div class="p-4 border-b flex justify-between items-center rounded-t-2xl">
                <h3 id="titulo-modal-adicional" class="text-lg font-bold text-amber-700">Novo Adicional</h3>
                <button onclick="fecharModalAdicional()" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
            </div>
            
            <div class="p-6 space-y-4">
                <input type="hidden" id="adicional-id">
                
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Nome do Adicional *</label>
                    <input type="text" id="adicional-nome" placeholder="Ex: Morango Extra" class="w-full border p-3 rounded-xl outline-none focus:border-amber-600">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Valor (R$) *</label>
                        <input type="number" id="adicional-valor" placeholder="0.00" step="0.01" class="w-full border p-3 rounded-xl outline-none focus:border-amber-600">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Status</label>
                        <select id="adicional-status" class="w-full border p-3 rounded-xl outline-none focus:border-amber-600">
                            <option value="ativo">✅ Ativo</option>
                            <option value="inativo">❌ Inativo</option>
                        </select>
                    </div>
                </div>

                <!-- NOVO CAMPO: SELETOR DE PRODUTO VINCULADO -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">
                        Vincular a Produto Específico
                        <span class="text-xs font-normal text-gray-500 ml-1">(opcional)</span>
                    </label>
                    <select id="adicional-produto-id" class="w-full border p-3 rounded-xl outline-none focus:border-amber-600 bg-white">
                        <option value="">📋 Disponível para todos os produtos (uso geral)</option>
                    </select>
                    <p class="text-xs text-gray-500 mt-1">
                        Deixe em branco para que este adicional apareça em todos os produtos
                    </p>
                </div>

                <div class="flex gap-3 pt-4 border-t">
                    <button onclick="fecharModalAdicional()" class="flex-1 bg-gray-200 text-gray-700 p-3 rounded-xl font-semibold hover:bg-gray-300 transition-all">Cancelar</button>
                    <button onclick="salvarAdicional()" id="btn-salvar-adicional" class="flex-1 bg-amber-600 text-white p-3 rounded-xl font-bold shadow-lg hover:shadow-none transition-all">Salvar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="mt-auto py-6 text-center border-t border-[#d7ccc8] bg-white rounded-t-2xl shadow-sm max-w-4xl mx-auto w-full">
        <div class="space-y-2">
            <p class="text-[#5d4037] font-semibold text-sm">Ateliê Mariana Almeida</p>
            <p class="text-[#8d6e63] text-xs italic">"Feito com amor ❤️"</p>
            <div class="pt-2 border-t border-gray-100 mt-2">
                <p class="text-[#a1887f] text-xs">
                    Desenvolvido por <span class="font-semibold text-[#5d4037]">Prosittes</span> © 2026
                </p>
            </div>
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getFirestore, collection, addDoc, updateDoc, deleteDoc, doc, onSnapshot, getDoc, setDoc } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";
        import { getStorage, ref, uploadBytesResumable, getDownloadURL } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-storage.js";

        const firebaseConfig = {
            apiKey: "AIzaSyA93ymW78OYYHc2qGoF-5D_RgWdCzkxh58",
            authDomain: "atelie-mariana.firebaseapp.com",
            projectId: "atelie-mariana",
            storageBucket: "atelie-mariana.firebasestorage.app",
            messagingSenderId: "416743252478",
            appId: "1:416743252478:web:543a9c03574dfca3d960af"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const storage = getStorage(app);

        // VARIÁVEIS GLOBAIS
        let statusLojaAtual = 'fechada';
        let fotoNovaProduto = null;
        let fotoURLProduto = '';
        let produtoEditando = null;
        let listaProdutosCache = []; // Cache para preencher o seletor de produtos

        // LOGIN
        window.verificarSenha = () => {
            if(document.getElementById('senha').value === 'mariana2026') {
                document.getElementById('login-area').classList.add('hidden');
                document.getElementById('admin-area').classList.remove('hidden');
                initSistema();
            } else { 
                alert('Senha incorreta!'); 
            }
        };

        // INICIALIZAR SISTEMA
        function initSistema() {
            carregarStatusLoja();
            carregarProdutos();
            carregarAdicionais();
        }

        // NAVEGAÇÃO ENTRE ABAS
        window.mostrarAba = (aba) => {
            // Esconder todas
            document.getElementById('conteudo-produtos').classList.add('hidden');
            document.getElementById('conteudo-adicionais').classList.add('hidden');
            
            // Resetar estilos
            document.getElementById('aba-produtos').className = 'flex-1 py-4 px-6 font-semibold text-gray-500 hover:text-[#5d4037] transition-all';
            document.getElementById('aba-adicionais').className = 'flex-1 py-4 px-6 font-semibold text-gray-500 hover:text-[#5d4037] transition-all';
            
            // Mostrar selecionada
            document.getElementById(`conteudo-${aba}`).classList.remove('hidden');
            document.getElementById(`aba-${aba}`).className = 'flex-1 py-4 px-6 font-semibold text-[#5d4037] border-b-2 border-[#5d4037] bg-[#faf7f5] transition-all';
        };

        // ==================== CONTROLE STATUS DA LOJA ====================
        
        async function carregarStatusLoja() {
            onSnapshot(doc(db, "config", "loja"), (doc) => {
                if (doc.exists()) {
                    statusLojaAtual = doc.data().status || 'fechada';
                    atualizarBotaoStatusLoja();
                } else {
                    // Criar documento padrão
                    setDoc(doc(db, "config", "loja"), { status: 'fechada', atualizadoEm: new Date().toISOString() });
                }
            });
        }

        function atualizarBotaoStatusLoja() {
            const btn = document.getElementById('btn-status-loja');
            if (statusLojaAtual === 'aberta') {
                btn.textContent = '🟢 Loja Aberta';
                btn.className = 'px-4 py-2 rounded-lg text-white font-bold text-sm transition-all shadow-md hover:shadow-lg transform hover:scale-105 status-aberta';
            } else {
                btn.textContent = '🔴 Loja Fechada';
                btn.className = 'px-4 py-2 rounded-lg text-white font-bold text-sm transition-all shadow-md hover:shadow-lg transform hover:scale-105 status-fechada';
            }
        }

        window.toggleStatusLoja = async () => {
            const novoStatus = statusLojaAtual === 'aberta' ? 'fechada' : 'aberta';
            try {
                await setDoc(doc(db, "config", "loja"), { 
                    status: novoStatus, 
                    atualizadoEm: new Date().toISOString() 
                });
                alert(`Loja ${novoStatus === 'aberta' ? 'ABERTA' : 'FECHADA'} com sucesso!`);
            } catch (e) {
                console.error(e);
                alert('Erro ao alterar status');
            }
        };

        // ==================== PRODUTOS ====================

        function carregarProdutos() {
            onSnapshot(collection(db, "produtos"), (snapshot) => {
                const lista = document.getElementById('lista-produtos');
                lista.innerHTML = '';
                
                // Atualizar cache para uso no modal de adicionais
                listaProdutosCache = [];
                
                if (snapshot.empty) {
                    lista.innerHTML = '<p class="text-center text-gray-400 py-8">Nenhum produto cadastrado</p>';
                    return;
                }
                
                snapshot.forEach((d) => {
                    const p = d.data();
                    const isAtivo = p.status === 'ativo';
                    
                    // Guardar no cache para o seletor de adicionais
                    listaProdutosCache.push({
                        id: d.id,
                        nome: p.nome || 'Produto sem nome'
                    });
                    
                    lista.innerHTML += `
                        <div class="bg-white border rounded-xl p-4 flex items-center gap-4 ${isAtivo ? 'border-gray-200' : 'border-red-200 bg-red-50 opacity-75'}">
                            <img src="${p.foto || 'https://via.placeholder.com/80?text=Sem+Foto'}" class="w-20 h-20 rounded-lg object-cover border flex-shrink-0">
                            
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <h4 class="font-bold text-[#5d4037] truncate">${p.nome}</h4>
                                    ${!isAtivo ? '<span class="text-[10px] bg-red-200 text-red-700 px-2 py-1 rounded-full">INATIVO</span>' : ''}
                                </div>
                                <p class="text-sm text-[#a1887f] font-semibold">R$ ${p.preco ? p.preco.toFixed(2) : '0.00'}</p>
                                <p class="text-xs text-gray-500 truncate">${p.descricao || ''}</p>
                                ${p.especificacoes ? '<span class="inline-block bg-blue-100 text-blue-700 text-[10px] px-2 py-1 rounded-full mt-1">📋 Com especificações</span>' : ''}
                            </div>
                            
                            <div class="flex flex-col gap-2 flex-shrink-0">
                                <button onclick="editarProduto('${d.id}')" class="bg-blue-50 text-blue-600 p-2 rounded-lg hover:bg-blue-600 hover:text-white transition-all text-xs font-semibold">Editar</button>
                                <button onclick="excluirProduto('${d.id}')" class="bg-red-50 text-red-500 p-2 rounded-lg hover:bg-red-500 hover:text-white transition-all text-xs font-semibold">Excluir</button>
                            </div>
                        </div>
                    `;
                });
            });
        }

        window.abrirModalProduto = () => {
            produtoEditando = null;
            fotoNovaProduto = null;
            fotoURLProduto = '';
            
            document.getElementById('titulo-modal-produto').textContent = 'Novo Produto';
            document.getElementById('produto-id').value = '';
            document.getElementById('produto-nome').value = '';
            document.getElementById('produto-preco').value = '';
            document.getElementById('produto-desc').value = '';
            document.getElementById('produto-especificacoes').value = '';
            document.getElementById('produto-status').value = 'ativo';
            
            document.getElementById('produto-upload-area').classList.remove('hidden');
            document.getElementById('produto-preview-area').classList.add('hidden');
            document.getElementById('produto-progress').classList.add('hidden');
            
            document.getElementById('modal-produto').classList.remove('hidden');
        };

        window.editarProduto = async (id) => {
            const docRef = doc(db, "produtos", id);
            const docSnap = await getDoc(docRef);
            
            if (docSnap.exists()) {
                const p = docSnap.data();
                produtoEditando = id;
                fotoURLProduto = p.foto || '';
                
                document.getElementById('titulo-modal-produto').textContent = 'Editar Produto';
                document.getElementById('produto-id').value = id;
                document.getElementById('produto-nome').value = p.nome || '';
                document.getElementById('produto-preco').value = p.preco || '';
                document.getElementById('produto-desc').value = p.descricao || '';
                document.getElementById('produto-especificacoes').value = p.especificacoes || '';
                document.getElementById('produto-status').value = p.status || 'ativo';
                
                if (p.foto) {
                    document.getElementById('produto-preview-img').src = p.foto;
                    document.getElementById('produto-upload-area').classList.add('hidden');
                    document.getElementById('produto-preview-area').classList.remove('hidden');
                } else {
                    document.getElementById('produto-upload-area').classList.remove('hidden');
                    document.getElementById('produto-preview-area').classList.add('hidden');
                }
                
                document.getElementById('produto-progress').classList.add('hidden');
                document.getElementById('modal-produto').classList.remove('hidden');
            }
        };

        window.fecharModalProduto = () => {
            document.getElementById('modal-produto').classList.add('hidden');
        };

        window.previewFotoProduto = (input) => {
            const file = input.files[0];
            if (file) {
                fotoNovaProduto = file;
                const reader = new FileReader();
                reader.onload = (e) => {
                    document.getElementById('produto-preview-img').src = e.target.result;
                    document.getElementById('produto-upload-area').classList.add('hidden');
                    document.getElementById('produto-preview-area').classList.remove('hidden');
                };
                reader.readAsDataURL(file);
            }
        };

        window.removerFotoProduto = () => {
            fotoNovaProduto = null;
            fotoURLProduto = '';
            document.getElementById('produto-foto-input').value = '';
            document.getElementById('produto-upload-area').classList.remove('hidden');
            document.getElementById('produto-preview-area').classList.add('hidden');
        };

        async function uploadFotoProduto(file) {
            return new Promise((resolve, reject) => {
                const nomeArquivo = `produtos/${Date.now()}_${file.name}`;
                const storageRef = ref(storage, nomeArquivo);
                const uploadTask = uploadBytesResumable(storageRef, file);

                document.getElementById('produto-progress').classList.remove('hidden');
                
                uploadTask.on('state_changed', 
                    (snapshot) => {
                        const progress = (snapshot.bytesTransferred / snapshot.totalBytes) * 100;
                        document.getElementById('produto-progress-bar').style.width = progress + '%';
                    },
                    (error) => reject(error),
                    async () => {
                        const url = await getDownloadURL(uploadTask.snapshot.ref);
                        resolve(url);
                    }
                );
            });
        }

