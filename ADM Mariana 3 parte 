        // Função para preencher o seletor de produtos no modal de adicionais
        function preencherSeletorProdutos(produtoIdSelecionado = '') {
            const select = document.getElementById('adicional-produto-id');
            
            // Manter a primeira opção (uso geral)
            select.innerHTML = '<option value="">📋 Disponível para todos os produtos (uso geral)</option>';
            
