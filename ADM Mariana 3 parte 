        function carregarAdicionais() {
            onSnapshot(collection(db, "adicionais"), (snapshot) => {
                const lista = document.getElementById('lista-adicionais');
                lista.innerHTML = '';
                
                if (snapshot.empty) {
                    lista.innerHTML = '<p class="text-center text-gray-400 py-8">Nenhum adicional cadastrado</p>';
                    return;
                }
                
                snapshot.forEach((d) => {
                    const a = d.data();
                    const isAtivo = a.status === 'ativo';
                    
                    // Buscar nome do produto vinculado (se existir)
                    let produtoVinculadoHTML = '';
                    if (a.produtoId) {
                        const produtoVinculado = listaProdutosCache.find(p => p.id === a.produtoId);
                        if (produtoVinculado) {
                            produtoVinculadoHTML = `<span class="inline-block bg-amber-100 text-amber-700 text-[10px] px-2 py-1 rounded-full mt-1">🔗 ${produtoVinculado.nome}</span>`;
                        } else {
                            produtoVinculadoHTML = `<span class="inline-block bg-gray-100 text-gray-600 text-[10px] px-2 py-1 rounded-full mt-1">🔗 Produto não encontrado</span>`;
                        }
                    } else {
                        produtoVinculadoHTML = `<span class="inline-block bg-green-100 text-green-700 text-[10px] px-2 py-1 rounded-full mt-1">🌐 Uso geral</span>`;
                    }
                    
                    lista.innerHTML += `
                        <div class="bg-white border rounded-xl p-4 flex items-center justify-between ${isAtivo ? 'border-gray-200' : 'border-gray-300 bg-gray-50 opacity-75'}">
                            <div>
                                <div class="flex items-center gap-2 mb-1">
                                    <h4 class="font-bold text-gray-800">${a.nome}</h4>
                                    ${!isAtivo ? '<span class="text-[10px] bg-gray-300 text-gray-600 px-2 py-1 rounded-full">INATIVO</span>' : ''}
                                </div>
                                <p class="text-sm text-amber-600 font-semibold">+ R$ ${a.valor ? a.valor.toFixed(2) : '0.00'}</p>
                                ${produtoVinculadoHTML}
                            </div>
                            
                            <div class="flex gap-2">
                                <button onclick="editarAdicional('${d.id}')" class="bg-blue-50 text-blue-600 p-2 rounded-lg hover:bg-blue-600 hover:text-white transition-all text-xs font-semibold">Editar</button>
                                <button onclick="excluirAdicional('${d.id}')" class="bg-red-50 text-red-500 p-2 rounded-lg hover:bg-red-500 hover:text-white transition-all text-xs font-semibold">Excluir</button>
                            </div>
                        </div>
                    `;
                });
            });
        }

